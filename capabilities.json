{
  "dataRoles": [
    {
      "displayName": "Path Levels",
      "name": "pathLevels",
      "kind": "Grouping",
      "description": "Drag 2 or more columns here to define the flow hierarchy left to right (e.g. Region → Department → Team)"
    },
    {
      "displayName": "Value",
      "name": "value",
      "kind": "Measure",
      "description": "Flow weight or volume — drives ribbon width"
    },
    {
      "displayName": "Color Legend",
      "name": "legendField",
      "kind": "Grouping",
      "description": "Optional: drag the same field used as the Legend in a co-located chart here to match colors across visuals"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "pathLevels": { "min": 1 },
          "value": { "max": 1 },
          "legendField": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "select": [
            { "for": { "in": "pathLevels" } },
            { "bind": { "to": "legendField" } }
          ],
          "dataReductionAlgorithm": { "window": { "count": 10000 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "value" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "nodeSettings": {
      "displayName": "Nodes",
      "properties": {
        "nodeWidth": {
          "displayName": "Node Width (px)",
          "type": { "numeric": true }
        },
        "nodePadding": {
          "displayName": "Node Padding (px)",
          "type": { "numeric": true }
        },
        "nodeSort": {
          "displayName": "Node Sort",
          "type": {
            "enumeration": [
              { "displayName": "Default",            "value": "default"    },
              { "displayName": "Value (high → low)", "value": "value-desc" },
              { "displayName": "Value (low → high)", "value": "value-asc"  },
              { "displayName": "Alphabetical",       "value": "alpha"      }
            ]
          }
        },
        "highlightDir": {
          "displayName": "Highlight Direction",
          "type": {
            "enumeration": [
              { "displayName": "Downstream", "value": "downstream" },
              { "displayName": "Upstream",   "value": "upstream"   },
              { "displayName": "Both",       "value": "both"       }
            ]
          }
        }
      }
    },
    "linkSettings": {
      "displayName": "Flows",
      "properties": {
        "linkOpacity": {
          "displayName": "Flow Opacity",
          "type": { "numeric": true }
        },
        "minFlowValue": {
          "displayName": "Minimum Flow Value",
          "type": { "numeric": true }
        },
        "colorBySource": {
          "displayName": "Color by Source",
          "type": { "bool": true }
        },
        "colorSourceLevel": {
          "displayName": "Color Source Column",
          "type": {
            "enumeration": [
              { "displayName": "First Column", "value": "__default__" }
            ]
          }
        },
        "gradientFlows": {
          "displayName": "Gradient Flows",
          "type": { "bool": true }
        },
        "skipBlanks": {
          "displayName": "Hide Blank Nodes",
          "type": { "bool": true }
        }
      }
    },
    "labelSettings": {
      "displayName": "Labels",
      "properties": {
        "show": {
          "displayName": "Show Labels",
          "type": { "bool": true }
        },
        "fontFamily": {
          "displayName": "Font Family",
          "type": { "text": true }
        },
        "fontSize": {
          "displayName": "Font Size",
          "type": { "numeric": true }
        },
        "bold": {
          "displayName": "Bold",
          "type": { "bool": true }
        },
        "italic": {
          "displayName": "Italic",
          "type": { "bool": true }
        },
        "underline": {
          "displayName": "Underline",
          "type": { "bool": true }
        },
        "fontColor": {
          "displayName": "Font Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "position": {
          "displayName": "Position",
          "type": {
            "enumeration": [
              { "displayName": "Inside",  "value": "inside"  },
              { "displayName": "Outside", "value": "outside" }
            ]
          }
        },
        "followPath": {
          "displayName": "Follow Flow Path",
          "type": { "bool": true }
        },
        "showBackground": {
          "displayName": "Background",
          "type": { "bool": true }
        },
        "backgroundColor": {
          "displayName": "Background Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "backgroundTransparency": {
          "displayName": "Transparency",
          "type": { "numeric": true }
        }
      }
    },
    "valueSettings": {
      "displayName": "Data Labels",
      "properties": {
        "show": {
          "displayName": "Show Data Labels",
          "type": { "bool": true }
        },
        "target": {
          "displayName": "Show On",
          "type": {
            "enumeration": [
              { "displayName": "Nodes", "value": "nodes"   },
              { "displayName": "Flows", "value": "ribbons" }
            ]
          }
        },
        "labelFormat": {
          "displayName": "Format",
          "type": {
            "enumeration": [
              { "displayName": "Value",       "value": "value"   },
              { "displayName": "% of Total",  "value": "percent" },
              { "displayName": "Value and %", "value": "both"    }
            ]
          }
        },
        "position": {
          "displayName": "Position",
          "type": {
            "enumeration": [
              { "displayName": "Inside",  "value": "inside"  },
              { "displayName": "Outside", "value": "outside" },
              { "displayName": "Auto",    "value": "auto"    }
            ]
          }
        },
        "alignment": {
          "displayName": "Alignment",
          "type": {
            "enumeration": [
              { "displayName": "Left",   "value": "left"   },
              { "displayName": "Center", "value": "center" },
              { "displayName": "Right",  "value": "right"  }
            ]
          }
        },
        "displayUnits": {
          "displayName": "Display Units",
          "type": {
            "enumeration": [
              { "displayName": "Auto",      "value": "auto"      },
              { "displayName": "None",      "value": "none"      },
              { "displayName": "Thousands", "value": "thousands" },
              { "displayName": "Millions",  "value": "millions"  },
              { "displayName": "Billions",  "value": "billions"  }
            ]
          }
        },
        "decimalPlaces": {
          "displayName": "Decimal Places",
          "type": { "numeric": true }
        },
        "fontFamily": {
          "displayName": "Font Family",
          "type": { "text": true }
        },
        "fontSize": {
          "displayName": "Font Size",
          "type": { "numeric": true }
        },
        "bold": {
          "displayName": "Bold",
          "type": { "bool": true }
        },
        "italic": {
          "displayName": "Italic",
          "type": { "bool": true }
        },
        "underline": {
          "displayName": "Underline",
          "type": { "bool": true }
        },
        "fontColor": {
          "displayName": "Font Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "showBackground": {
          "displayName": "Background",
          "type": { "bool": true }
        },
        "backgroundColor": {
          "displayName": "Background Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "backgroundTransparency": {
          "displayName": "Transparency",
          "type": { "numeric": true }
        }
      }
    }
  },
  "privileges": [],
  "supportsLandingPage": true,
  "supportsHighlight": false,
  "supportsMultiVisualSelection": true,
  "sorting": {
    "default": {}
  }
}
