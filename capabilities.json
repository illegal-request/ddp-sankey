{
  "dataRoles": [
    {
      "displayName": "Path Levels",
      "name": "pathLevels",
      "kind": "Grouping",
      "description": "Drag 2 or more columns here to define the flow hierarchy left to right (e.g. Region → Department → Team)"
    },
    {
      "displayName": "Value",
      "name": "value",
      "kind": "Measure",
      "description": "Flow weight or volume — drives ribbon width"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "pathLevels": { "min": 1 },
          "value": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "select": [{ "for": { "in": "pathLevels" } }],
          "dataReductionAlgorithm": { "window": { "count": 10000 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "value" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "nodeSettings": {
      "displayName": "Nodes",
      "properties": {
        "nodeWidth": {
          "displayName": "Node Width (px)",
          "type": { "numeric": true }
        },
        "nodePadding": {
          "displayName": "Node Padding (px)",
          "type": { "numeric": true }
        }
      }
    },
    "linkSettings": {
      "displayName": "Flows",
      "properties": {
        "linkOpacity": {
          "displayName": "Flow Opacity",
          "type": { "numeric": true }
        },
        "colorBySource": {
          "displayName": "Color by Source",
          "type": { "bool": true }
        }
      }
    },
    "labelSettings": {
      "displayName": "Labels",
      "properties": {
        "show": {
          "displayName": "Show Labels",
          "type": { "bool": true }
        },
        "fontFamily": {
          "displayName": "Font Family",
          "type": { "text": true }
        },
        "fontSize": {
          "displayName": "Font Size",
          "type": { "numeric": true }
        },
        "bold": {
          "displayName": "Bold",
          "type": { "bool": true }
        },
        "italic": {
          "displayName": "Italic",
          "type": { "bool": true }
        },
        "underline": {
          "displayName": "Underline",
          "type": { "bool": true }
        },
        "fontColor": {
          "displayName": "Font Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "position": {
          "displayName": "Position",
          "type": {
            "enumeration": [
              { "displayName": "Inside",  "value": "inside"  },
              { "displayName": "Outside", "value": "outside" }
            ]
          }
        },
        "followPath": {
          "displayName": "Follow Flow Path",
          "type": { "bool": true }
        },
        "showBackground": {
          "displayName": "Background",
          "type": { "bool": true }
        },
        "backgroundColor": {
          "displayName": "Background Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "backgroundTransparency": {
          "displayName": "Transparency",
          "type": { "numeric": true }
        }
      }
    },
    "valueSettings": {
      "displayName": "Data Labels",
      "properties": {
        "show": {
          "displayName": "Show Data Labels",
          "type": { "bool": true }
        },
        "target": {
          "displayName": "Show On",
          "type": {
            "enumeration": [
              { "displayName": "Nodes", "value": "nodes"   },
              { "displayName": "Flows", "value": "ribbons" }
            ]
          }
        },
        "position": {
          "displayName": "Position",
          "type": {
            "enumeration": [
              { "displayName": "Inside",  "value": "inside"  },
              { "displayName": "Outside", "value": "outside" },
              { "displayName": "Auto",    "value": "auto"    }
            ]
          }
        },
        "alignment": {
          "displayName": "Alignment",
          "type": {
            "enumeration": [
              { "displayName": "Left",   "value": "left"   },
              { "displayName": "Center", "value": "center" },
              { "displayName": "Right",  "value": "right"  }
            ]
          }
        },
        "fontFamily": {
          "displayName": "Font Family",
          "type": { "text": true }
        },
        "fontSize": {
          "displayName": "Font Size",
          "type": { "numeric": true }
        },
        "bold": {
          "displayName": "Bold",
          "type": { "bool": true }
        },
        "italic": {
          "displayName": "Italic",
          "type": { "bool": true }
        },
        "underline": {
          "displayName": "Underline",
          "type": { "bool": true }
        },
        "fontColor": {
          "displayName": "Font Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "showBackground": {
          "displayName": "Background",
          "type": { "bool": true }
        },
        "backgroundColor": {
          "displayName": "Background Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "backgroundTransparency": {
          "displayName": "Transparency",
          "type": { "numeric": true }
        }
      }
    }
  },
  "privileges": [],
  "supportsHighlight": false,
  "sorting": {
    "default": {}
  }
}
